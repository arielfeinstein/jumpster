generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id          String        @id
  email       String        @unique
  username    String        @unique
  createdAt   DateTime      @default(now())
  levels      Level[]
  likes       Like[]
  bookmarks   Bookmark[]
  playHistory PlayHistory[]
}

model Level {
  id          String        @id @default(cuid())
  title       String
  difficulty  String        @default("medium")
  data        Json?
  authorId    String
  author      User          @relation(fields: [authorId], references: [id])
  createdAt   DateTime      @default(now())
  published    Boolean      @default(false)
  publishedAt  DateTime?
  // Delete strategy:
  // - Unpublished level → hard delete (row removed permanently).
  // - Published level  → soft delete: data = null, deletedAt = now().
  //   Ghost level behavior by caller:
  //   | Caller                        | Behavior                                        |
  //   | Browse / My Levels queries    | WHERE deletedAt IS NULL — ghost never appears   |
  //   | History / Bookmarks queries   | Included; UI grays it out as "no longer available" |
  //   | GET /api/levels/:id (play)    | deletedAt IS NOT NULL → 404, no new sessions    |
  //   | POST /api/levels/:id/complete | Accepted regardless — in-flight sessions must finish |
  deletedAt    DateTime?
  likes       Like[]
  bookmarks   Bookmark[]
  playHistory PlayHistory[]
}

model Like {
  userId  String
  levelId String
  user    User   @relation(fields: [userId], references: [id])
  level   Level  @relation(fields: [levelId], references: [id])

  @@id([userId, levelId])
}

// Tracks a user's interaction with a level — one record per user-level pair.
// playCount increments each time the user plays; lastPlayed refreshes each time.
// completedAt is set on first completion and never overwritten.
model PlayHistory {
  id          String    @id @default(cuid())
  userId      String
  levelId     String
  playCount   Int       @default(1)
  lastPlayed  DateTime  @default(now())
  completedAt DateTime?

  user  User  @relation(fields: [userId], references: [id])
  level Level @relation(fields: [levelId], references: [id])

  @@unique([userId, levelId])
}

// Saves a level to the user's "Play Later" list.
model Bookmark {
  userId  String
  levelId String
  user    User   @relation(fields: [userId], references: [id])
  level   Level  @relation(fields: [levelId], references: [id])

  @@id([userId, levelId])
}
